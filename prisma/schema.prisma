// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String   @id @default(cuid())
  name          String
  walletAddress String?  @unique
  profession    String?
  bio           String?
  trustScore    Int      @default(0)
  createdAt     DateTime @default(now())

  sentThanks     Thank[] @relation("SentThanks")
  receivedThanks Thank[] @relation("ReceivedThanks")
}

model Thank {
  id          String   @id @default(cuid())
  note        String
  images      String   @default("[]") // JSON string of image URLs
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())

  senderId    String
  sender      User     @relation("SentThanks", fields: [senderId], references: [id])
  
  receiverId  String
  receiver    User     @relation("ReceivedThanks", fields: [receiverId], references: [id])

  tags        Tag[]    @relation("ThankTags")
}

model Tag {
  id     String  @id @default(cuid())
  name   String  @unique
  thanks Thank[] @relation("ThankTags")
}

