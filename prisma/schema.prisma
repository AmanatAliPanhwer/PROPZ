generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String   @id @default(cuid())
  authId         String   @unique
  email          String?
  name           String
  profilePicture String?
  profession     String?
  bio            String?
  trustScore     Int      @default(0)
  createdAt      DateTime @default(now())

  sentThanks     Thank[] @relation("SentThanks")
  receivedThanks Thank[] @relation("ReceivedThanks")
}

model Thank {
  id         String   @id @default(cuid())
  note       String
  images     String   @default("[]")
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())

  senderId   String
  sender     User     @relation("SentThanks", fields: [senderId], references: [id])

  receiverId String
  receiver   User     @relation("ReceivedThanks", fields: [receiverId], references: [id])

  tags       Tag[]    @relation("ThankTags")
}

model Tag {
  id     String  @id @default(cuid())
  name   String  @unique
  thanks Thank[] @relation("ThankTags")
}
